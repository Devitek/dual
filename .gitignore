# Learn more https://docs.expo.dev/guides/using-git

# Dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native — dossiers générés par `expo prebuild` (workflow CNG).
# On ne les versionne pas : ils sont régénérés à partir de app.json + config plugins.
/android
/ios
.kotlin/

# Sorties de build des modules natifs locaux (on versionne les sources, pas le build)
modules/**/build/
modules/**/.cxx/
modules/**/.gradle/
*.keystore

# Native build artifacts / secrets
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# Debug logs
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# Local env files
.env*.local
.env.local

# TypeScript
*.tsbuildinfo

# Expo export output
/dist

# Design handoff (reference material, not shipped)
/design_handoff_twinlens

# Screenshot renders (régénérés depuis store/screenshots/src via Chrome headless).
# Les copies canoniques vivent dans docs/assets et fastlane/metadata.
/store/screenshots/*.png
