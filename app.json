{
  "expo": {
    "name": "Dual",
    "slug": "dual",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "dual",
    "userInterfaceStyle": "dark",
    "platforms": [
      "android"
    ],
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.perso.dual",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-media-library",
        {
          "photosPermission": "Dual accède à votre galerie pour y enregistrer vos captures.",
          "savePhotosPermission": "Dual enregistre vos photos et vidéos dans votre galerie.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      "expo-status-bar",
      "expo-asset",
      "expo-font"
    ]
  }
}
