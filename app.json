{
  "expo": {
    "name": "TwinLens",
    "slug": "dual",
    "version": "1.2.0",
    "orientation": "portrait",
    "scheme": "dual",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "platforms": [
      "android"
    ],
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "fr.devitek.twinlens",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon-foreground.png",
        "backgroundImage": "./assets/adaptive-icon-background.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-media-library",
        {
          "savePhotosPermission": "TwinLens enregistre vos photos et vidéos dans votre galerie.",
          "isAccessMediaLocationEnabled": false,
          "granularPermissions": []
        }
      ],
      "expo-status-bar",
      "expo-asset",
      "expo-font",
      "expo-sharing",
      "expo-video",
      "expo-localization"
    ]
  }
}
